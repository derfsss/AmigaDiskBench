# Performance stability over time with linear trend
[Profile]
Name        = "Trend"
Description = "Track performance drift with a linear trend line per drive"
ChartType   = line

[XAxis]
Source      = test_index
Label       = "Test Run"
Format      = integer

[YAxis]
Source      = mb_per_sec
Label       = "MB/s"
AutoScale   = yes

[Series]
GroupBy     = drive
SortX       = no

[Filters]
DefaultDateRange = month

[TrendLine]
Style     = linear
PerSeries = yes
