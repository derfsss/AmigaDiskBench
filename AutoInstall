.KEY platform
.BRA {
.KET }

; AutoInstall for AmigaDiskBench
; Disk Benchmark for AmigaOS 4
; Generated by AmiUpdate Integration Toolkit

; Get the install path from APPDIR
Set AUInstallPath `GetEnv AppDir/AmigaDiskBench`

; Fallback to default path if APPDIR not set
If "$AUInstallPath" EQ ""
  Set AUInstallPath "SYS:Utilities"
EndIf

; Create target directory
failat 21
makedir "$AUInstallPath" ALL
failat 10

; Install critical files via CopyStore (enables RollBack)
CopyStore AmigaDiskBench "$AUInstallPath"

; Install additional files
Copy AmigaDiskBench.info "$AUInstallPath" CLONE QUIET
Copy Visualizations "$AUInstallPath/Visualizations" ALL CLONE QUIET
Copy Visualizations.info "$AUInstallPath" CLONE QUIET
Copy AmigaDiskBench.readme "$AUInstallPath" CLONE QUIET

; Installation complete
echo ""
echo "AmigaDiskBench has been updated."
echo ""

UnSet AUInstallPath
